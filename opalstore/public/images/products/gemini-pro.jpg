<svg xmlns="http://www.w3.org/2000/svg" width="400" height="300" viewBox="0 0 400 300">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a1a2e"/>
      <stop offset="100%" style="stop-color:#16213e"/>
    </linearGradient>
    <linearGradient id="accent" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#4285f4"/>
      <stop offset="50%" style="stop-color:#34a853"/>
      <stop offset="100%" style="stop-color:#fbbc05"/>
    </linearGradient>
  </defs>
  <rect width="400" height="300" fill="url(#bg)"/>
  <circle cx="200" cy="120" r="50" fill="none" stroke="url(#accent)" stroke-width="3"/>
  <text x="200" y="135" text-anchor="middle" fill="white" font-family="Arial" font-size="28" font-weight="bold">G</text>
  <text x="200" y="210" text-anchor="middle" fill="white" font-family="Arial" font-size="24" font-weight="bold">Gemini Pro</text>
  <text x="200" y="240" text-anchor="middle" fill="rgba(255,255,255,0.5)" font-family="Arial" font-size="14">Google AI Premium</text>
</svg>
